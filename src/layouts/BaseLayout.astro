---
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/glass.css";

import Footer from "../components/common/Footer.astro";
import ThemeToggle from "../components/common/ThemeToggle.astro";
import Chatbot from "../components/common/Chatbot.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Arturo Calanche | Portfolio",
  description = "Software Developer, BI Analyst & Fraud Prevention Specialist",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="/favicon.ico" />

    <script is:inline>
      // Corre antes del primer paint para que no haya flash del tema
      // equivocado al cargar o recargar la página.
      (function () {
        const stored = localStorage.getItem("theme");
        const theme = stored === "light" || stored === "dark" ? stored : "dark";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body>
    <div class="aurora-bg">
      <div class="aurora aurora-1"></div>
      <div class="aurora aurora-2"></div>
      <div class="aurora aurora-3"></div>
    </div>

    <main>
      <slot />
    </main>

    <Footer />
    <ThemeToggle />
    <Chatbot />
  </body>
</html>