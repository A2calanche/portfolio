---
import { getCollection } from "astro:content";

const allExperience = await getCollection("experience",
  ({ data }) => data.lang === "es" && !data.draft
);

const preview = allExperience.slice(0, 3);

---

<section id="experience" class="experience">
  <h2>Experiencia</h2>

  <ol class="timeline">
    {preview .map((job) => (
      <li class="timeline__item">
        <div class="timeline__marker" aria-hidden="true"></div>

        <div class="timeline__content">
          <div class="timeline__header">
            <h3>{job.data.role}</h3>
            <span class="timeline__period">{job.data.period}</span>
          </div>

          <p class="timeline__company">{job.data.company}</p>
          <ul class= "timeline__responsabilities">{job.data.responsabilities.map((resp) => (
            <li>{resp}</li>
          ))}</ul>

          {job.data.stack && (
            <ul class="timeline__stack">
              {job.data.stack.map((tech) => (
                <li>{tech}</li>
              ))}
            </ul>
          )}
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .experience {
    padding-block: 4rem;
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  h2 {
    text-align: center;
    margin-bottom: 3rem;
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 0.4rem;
    width: 2px;
    background: var(--glass-border, rgba(255, 255, 255, 0.18));
  }

  .timeline__item {
    position: relative;
    padding-left: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    top: 0.35rem;
    left: 0;
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-accent-glass, rgba(168, 85, 247, 0.15));
  }

  .timeline__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .timeline__header h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .timeline__period {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono, monospace);
    white-space: nowrap;
  }

  .timeline__company {
    margin: 0.25rem 0 0.75rem;
    color: var(--color-accent-text, var(--color-accent));
    font-weight: 600;
  }

  .timeline__description {
    margin: 0 0 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .timeline__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .timeline__stack li {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.18));
    border-radius: 999px;
    color: var(--color-text-muted);
  }
</style>