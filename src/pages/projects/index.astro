---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allProjects = await getCollection(
  "projects",
  ({ data }) => data.lang === "es" && !data.draft
);
---

<BaseLayout
  title="Proyectos | Arturo Calanche"
  description="Case studies de proyectos de desarrollo full-stack, automatización y análisis de datos."
>
  <section class="projects-index">
    <header>
      <a class="back" href="/">← Volver al inicio</a>
      <h1>Proyectos</h1>
      <p class="subtitle">
        Case studies con el problema, la solución y el resultado de cada proyecto.
      </p>
    </header>

    {allProjects.length === 0 ? (
      <p class="empty">Todavía no hay proyectos publicados. Volvé pronto.</p>
    ) : (
      <div class="grid">
        {allProjects.map((project) => (
          <a class="card" href={`/projects/${project.data.slug}`}>
            <h2>{project.data.title}</h2>
            <p>{project.data.problem}</p>

            <ul class="stack">
              {project.data.stack.map((tech) => (
                <li>{tech}</li>
              ))}
            </ul>

            <span class="card__link">Ver caso de estudio →</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .projects-index {
    max-width: 72rem;
    margin-inline: auto;
    padding: 4rem 1.5rem;
  }

  header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .back:hover {
    color: var(--color-accent);
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }

  .subtitle {
    color: var(--color-text-muted);
    max-width: 40ch;
    margin-inline: auto;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 1rem;
    background: var(--glass-bg, rgba(255, 255, 255, 0.08));
    backdrop-filter: blur(var(--glass-blur, 12px)) saturate(var(--glass-sat, 180%));
    -webkit-backdrop-filter: blur(var(--glass-blur, 12px)) saturate(var(--glass-sat, 180%));
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.18));
    box-shadow: var(--glass-shadow, none);
    color: inherit;
    text-decoration: none;
    transition: transform 200ms ease, border-color 200ms ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }

  .card p {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }

  .stack li {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.18));
    border-radius: 999px;
    color: var(--color-text-muted);
  }

  .card__link {
    font-weight: 600;
    color: var(--color-accent-text, var(--color-accent));
  }
</style>